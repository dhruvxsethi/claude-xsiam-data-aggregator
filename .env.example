# --- AlienVault OTX ---
# Get free key at: https://otx.alienvault.com/api
OTX_API_KEY=your_otx_api_key_here

# --- abuse.ch (covers ThreatFox + URLhaus — one key for both) ---
# Free at: https://abuse.ch/account → "Get API key"
ABUSECH_API_KEY=

# --- CISA KEV ---
# No key needed — public feed

# --- NVD (National Vulnerability Database) ---
# Optional but increases rate limits — https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# --- Anthropic (Claude AI News Collector) ---
# Used to search the web for live threat news across all target sectors
# Get a key at: https://console.anthropic.com (free tier available)
ANTHROPIC_API_KEY=

# --- Filtering ---
# Comma-separated sectors to track
# Supported out of the box: banking, telecom, government
# The Claude AI collector works with any sector name; other collectors have
# built-in detection for banking, telecom, and government only.
TARGET_SECTORS=banking,telecom,government
