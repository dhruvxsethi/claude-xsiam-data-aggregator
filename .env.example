# --- AlienVault OTX ---
# Get free key at: https://otx.alienvault.com/api
OTX_API_KEY=your_otx_api_key_here

# --- CISA KEV ---
# No key needed — public feed

# --- NVD (National Vulnerability Database) ---
# Optional but increases rate limits — https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# --- Cortex XSIAM ---
# XSIAM_BASE_URL = the full API URL from the Custom HTTP Based Collector screen
# XSIAM_API_KEY  = the token from the same screen
XSIAM_BASE_URL=https://api-YOUR-TENANT.xdr.us.paloaltonetworks.com/logs/v1/event
XSIAM_API_KEY=your_xsiam_token_here

# --- Schedule ---
# Daily run time in UTC (24h format)
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=0

# --- Filtering ---
# Comma-separated sectors to track (leave blank for all)
TARGET_SECTORS=banking,finance,financial
